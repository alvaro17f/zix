#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

BIN_DIR="./zig-out/bin"
EXE="$BIN_DIR/zix"
TEST_EXE="$BIN_DIR/zix-test"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info()  { printf "${BLUE}▶${NC} %s\n" "$*"; }
ok()    { printf "${GREEN}✓${NC} %s\n" "$*"; }
warn()  { printf "${YELLOW}⚠${NC} %s\n" "$*" >&2; }
err()   { printf "${RED}✗${NC} %s\n" "$*" >&2; }

ensure_build() {
    if [[ ! -x "$TEST_EXE" ]] || [[ ! -x "$EXE" ]]; then
        warn "binaries missing, building..."
        task_build
    fi
}

task_build() {
    info "building..."
    zig build --summary all
    ok "build complete"
}

task_run() {
    ensure_build
    info "running zix..."
    "$EXE" "$@"
}

task_test() {
    ensure_build
    info "running tests..."
    "$TEST_EXE"
}

task_coverage() {
    ensure_build
    rm -rf coverage
    info "running kcov..."
    local kcov_exit=0
    nix-shell -p kcov --run "kcov --include-pattern=src ./coverage $TEST_EXE" || kcov_exit=$?
    if [[ $kcov_exit -ne 0 && $kcov_exit -ne 1 ]]; then
        err "kcov failed with exit $kcov_exit"
        return $kcov_exit
    fi
    local json
    json=(coverage/*/coverage.json)
    if [[ -f "${json[0]}" ]]; then
        local pct covered total
        pct=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1]))['percent_covered'])" "${json[0]}")
        covered=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1]))['covered_lines'])" "${json[0]}")
        total=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1]))['total_lines'])" "${json[0]}")
        ok "coverage: ${pct}% (${covered}/${total} lines)"
    fi
}

task_vhs() {
    ensure_build
    info "recording vhs tape..."
    vhs ./vhs/zix.tape
}

task_clean() {
    info "cleaning artifacts..."
    rm -rf zig-out .zig-cache coverage
    ok "clean complete"
}

task_fmt() {
    info "formatting zig sources..."
    zig fmt src/
    ok "format complete"
}

task_default() {
    task_build
    task_run "$@"
}

task_help() {
    cat <<EOF
usage: ./taskfile <task> [args]

tasks:
  build    compile project
  run      execute zix binary (builds if missing)
  test     run test suite (builds if missing)
  coverage run tests under kcov and print line coverage
  fmt      run zig fmt on src/
  clean    remove zig-out, .zig-cache, and coverage
  vhs      record demo tape
  default  build + run
EOF
}

main() {
    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        build)    task_build "$@" ;;
        run)      task_run "$@" ;;
        test)     task_test "$@" ;;
        coverage) task_coverage "$@" ;;
        fmt)      task_fmt "$@" ;;
        clean)    task_clean "$@" ;;
        vhs)      task_vhs "$@" ;;
        default)  task_default "$@" ;;
        help|--help|-h) task_help ;;
        *)
            err "unknown task: $cmd"
            task_help
            exit 1
            ;;
    esac
}

main "$@"
