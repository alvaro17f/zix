#!/usr/bin/env bash
set -euo pipefail

cmd="${1:-help}"
shift || true

case "$cmd" in
  build)
    zig build --summary all
    ;;
  run)
    ./zig-out/bin/zix "$@"
    ;;
  test)
    ./zig-out/bin/zix-test
    ;;
  coverage)
    rm -rf coverage
    nix-shell -p kcov --run "kcov --include-pattern=src ./coverage ./zig-out/bin/zix-test"
    ;;
  vhs)
    vhs ./vhs/zix.tape
    ;;
  default)
    zig build --summary all
    ./zig-out/bin/zix "$@"
    ;;
  help|*)
    cat <<'EOF'
usage: ./taskfile <task>

tasks:
  build    zig build --summary all
  run      ./zig-out/bin/zix <args>
  test     ./zig-out/bin/zix-test
  coverage kcov instrumentation run
  vhs      record demo tape
  default  build + run
EOF
    ;;
esac
